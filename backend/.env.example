# ─── AURA-CX Backend – Environment Variables ─────────────────────────────────
# Copy to .env and fill in real values. DO NOT commit .env to version control.

# ── Core ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
USE_MOCK_DATA=false

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://aura:aura@localhost:5432/aura_cx

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=                           # python -c "import secrets; print(secrets.token_urlsafe(32))"
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
VECTOR_PROVIDER=chroma

# ── Auth & JWT ────────────────────────────────────────────────────────────────
SECRET_KEY=                               # python -c "import secrets; print(secrets.token_urlsafe(64))"
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Bootstrap Admin ──────────────────────────────────────────────────────────
BOOTSTRAP_TENANT_ID=tenant-default
BOOTSTRAP_TENANT_NAME=My Workspace
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=changeme

# ── Webhook Security ─────────────────────────────────────────────────────────
WEBHOOK_SIGNING_SECRET=                   # python -c "import secrets; print(secrets.token_hex(32))"

# ── Encryption ────────────────────────────────────────────────────────────────
ENCRYPTION_KEY=                           # python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_TENANT=500
RATE_LIMIT_WEBHOOK_PER_IP=20

# ── AI Providers ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=                           # https://aistudio.google.com/apikey
GEMINI_MODEL=gemini-1.5-pro-latest

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=                        # https://dashboard.stripe.com/apikeys
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# ── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=                       # https://console.twilio.com/
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Pinecone (if VECTOR_PROVIDER=pinecone) ────────────────────────────────────
PINECONE_API_KEY=                         # https://app.pinecone.io/
PINECONE_HOST=

# ── Social Monitor: X (Twitter) API v2 ────────────────────────────────────────
X_BEARER_TOKEN=                           # https://developer.x.com/en/portal/dashboard

# ── Social Monitor: Threads (Meta) ────────────────────────────────────────────
THREADS_ACCESS_TOKEN=                     # https://developers.facebook.com/apps/

# ── Social Monitor: Email (IMAP) ──────────────────────────────────────────────
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_USE_SSL=true

# ── Social Monitor: Polling ───────────────────────────────────────────────────
SOCIAL_MONITOR_POLL_INTERVAL=300
COMPLAINT_CONFIDENCE_THRESHOLD=0.70
