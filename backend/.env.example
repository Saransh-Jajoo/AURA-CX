# AURA-CX backend environment
USE_MOCK_DATA=false
ENVIRONMENT=production
FRONTEND_URL=http://localhost:3000

# Postgres metadata store
DATABASE_URL=postgresql+asyncpg://aura:aura@postgres:5432/aura_cx

# JWT and bootstrap tenant admin
SECRET_KEY=replace-with-at-least-32-random-characters
BOOTSTRAP_TENANT_ID=tenant-default
BOOTSTRAP_TENANT_NAME=AURA-CX Workspace
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-password

# Signed webhook ingestion
WEBHOOK_SIGNING_SECRET=

# Gemini reasoning and embeddings
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro-latest
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Vector storage: pinecone or chroma
VECTOR_PROVIDER=chroma
PINECONE_API_KEY=
PINECONE_INDEX=aura-cx
PINECONE_HOST=
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_COLLECTION=aura_cx
COSINE_THRESHOLD=0.92

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

