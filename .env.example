# ═══════════════════════════════════════════════════════════════════
# AURA-CX Environment Configuration
# ═══════════════════════════════════════════════════════════════════
# SETUP: Copy this file to .env and fill in your values:
#   cp .env.example .env        (Linux/Mac)
#   copy .env.example .env      (Windows)
#
# Then run: docker-compose up -d --build
# ═══════════════════════════════════════════════════════════════════

ENVIRONMENT=development
USE_MOCK_DATA=true

# ── Database ─────────────────────────────────────────────────────
POSTGRES_USER=aura
POSTGRES_PASSWORD=changeme_db_password
DATABASE_URL=postgresql+asyncpg://aura:changeme_db_password@postgres:5432/aura_cx

# ── Redis ────────────────────────────────────────────────────────
REDIS_PASSWORD=changeme_redis_password
REDIS_URL=redis://:changeme_redis_password@redis:6379/0
CELERY_BROKER_URL=redis://:changeme_redis_password@redis:6379/1
CELERY_RESULT_BACKEND=redis://:changeme_redis_password@redis:6379/2

# ── ChromaDB (Vector Store) ──────────────────────────────────────
CHROMA_HOST=chroma
CHROMA_PORT=8000
VECTOR_PROVIDER=chroma

# ── Authentication ───────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme_generate_a_64char_hex_secret
WEBHOOK_SIGNING_SECRET=changeme_generate_another_hex_secret
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=changeme_generate_fernet_key

# ── Bootstrap Admin Account ─────────────────────────────────────
BOOTSTRAP_TENANT_ID=tenant-default
BOOTSTRAP_TENANT_NAME=AURA-CX Workspace
BOOTSTRAP_ADMIN_EMAIL=admin@aura.cx
BOOTSTRAP_ADMIN_PASSWORD=replace_with_a_strong_12plus_character_password

# ── AI Providers (BYOK) ─────────────────────────────────────────
AI_PROVIDER=gemini
AI_FALLBACK_ORDER=gemini,openai,anthropic,openrouter,mistral,ollama,self_hosted
AI_TIMEOUT_SECONDS=45
AI_MAX_RETRIES=2
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-pro-latest
GEMINI_EMBEDDING_MODEL=text-embedding-004
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4.1-mini
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1
SELF_HOSTED_AI_BASE_URL=
SELF_HOSTED_AI_API_KEY=
SELF_HOSTED_AI_MODEL=

# ── Stripe (use mock values for development) ─────────────────────
STRIPE_SECRET_KEY=sk_test_mock
STRIPE_PRICE_STARTER=price_starter_mock
STRIPE_PRICE_PRO=price_pro_mock
STRIPE_PRICE_ENTERPRISE=price_enterprise_mock

# ── Twilio (use mock values for development) ─────────────────────
TWILIO_ACCOUNT_SID=AC_mock_sid
TWILIO_AUTH_TOKEN=mock_auth_token
TWILIO_PHONE_NUMBER=+15555555555

# ── Multilingual ─────────────────────────────────────────────────
SUPPORTED_LANGUAGES=en,hi,mr,ta,bn,gu,te,kn,ml

# ── Social Monitor (optional — leave blank to disable) ───────────
X_BEARER_TOKEN=
THREADS_ACCESS_TOKEN=
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_USE_SSL=true
SOCIAL_MONITOR_POLL_INTERVAL=300
COMPLAINT_CONFIDENCE_THRESHOLD=0.70
